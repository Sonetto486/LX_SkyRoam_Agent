# 应用配置
APP_NAME=LX SkyRoam Agent
VERSION=1.0.0
DEBUG=true

# 服务器配置
HOST=0.0.0.0
PORT=8000
ALLOWED_HOSTS=["*"]

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/skyroam

# Redis配置
# 优先使用完整URL（可选）：
REDIS_URL=
# 或使用分项配置：
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_USE_TLS=false

# Celery配置
# rediss://default:<password>@<host>:<port>/1
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_BROKER_DB=1
CELERY_BACKEND_DB=2

# 智谱 AI 配置（正确！）
OPENAI_API_BASE=https://open.bigmodel.cn/api/paas/v4/
OPENAI_API_KEY=7d50b250693141feaed628adbb9c240d.gAosc4EfXfDeGNAa
OPENAI_MODEL=glm-4-flash
OPENAI_CHAT_MODEL=glm-4-flash
OPENAI_EMBEDDING_MODEL=embedding-2
EMBEDDING_PROVIDER=openai
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v2
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.7

# 第三方API配置
WEATHER_API_KEY=your-openweathermap-api-key

# Amadeus API配置
AMADEUS_CLIENT_ID=your-amadeus-client-id
AMADEUS_CLIENT_SECRET=your-amadeus-client-secret
AMADEUS_API_BASE=https://test.api.amadeus.com
AMADEUS_TOKEN_URL=https://test.api.amadeus.com/v1/security/oauth2/token

HOTEL_API_KEY=your-booking-api-key
MAP_API_KEY=your-google-maps-api-key

# 安全配置
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=360

# 文件存储
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10 MB
LOG_RETENTION=5
LOG_COMPRESSION=zip
LOG_TO_CONSOLE=true
LOG_TO_FILE=true

# 缓存配置
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# 任务配置
TASK_TIMEOUT=300
MAX_CONCURRENT_TASKS=10
