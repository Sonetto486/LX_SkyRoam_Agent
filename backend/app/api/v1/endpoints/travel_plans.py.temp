@router.get("/{plan_id}/text-plan")
async def get_text_plan(
    plan_id: int,
    max_chars: int = Query(2000, ge=500, le=5000, description="وœ€ه¤§ه­—ç¬¦و•°é™گهˆ¶"),
    db: AsyncSession = Depends(get_async_db),
    current_user: Optional[User] = Depends(get_current_user_optional),
):
    """èژ·هڈ–ç؛¯و–‡وœ¬و—…è،Œو–¹و،ˆï¼ˆLLMç›´وژ¥ç”ںوˆگï¼Œن¸چن¾‌èµ–çˆ¬هڈ–و•°وچ®ï¼?
    
    و³¨و„ڈï¼ڑو­¤و–¹و،ˆهں؛ن؛ژLLMçں¥è¯†ه؛“ç”ںوˆگï¼Œهڈ¯èƒ½وœ‰و»‍هگژو€§ï¼Œن½†ن¸»è¦پو™¯ç‚¹ن؟،وپ¯é€ڑه¸¸وک¯ه‡†ç،®çڑ„م€?
    é€‚ç”¨ن؛ژه؟«é€ںو¦‚è§ˆç›®çڑ„هœ°çژ©و³•م€?
    
    ç»“و‍œن¼ڑç¼“ه­کهˆ° Redis 1 ه°ڈو—¶م€?
    """
    try:
        # ه°‌è¯•ن»ژç¼“ه­کèژ·هڈ?
        cache_key = f"text_plan:{plan_id}:{max_chars}"
        cached_result = await get_cache(cache_key)
        if cached_result:
            logger.info(f"ن»ژç¼“ه­کèژ·هڈ–ç؛¯و–‡وœ¬و–¹و،ˆ: plan_id={plan_id}")
            return cached_result
        
        service = TravelPlanService(db)
        # ه°‌è¯•èژ·هڈ–è®،هˆ’ï¼ˆç§پوœ‰وˆ–ه…¬ه¼€ï¼?
        plan = None
        is_public = False
        
        # ه…ˆه°‌è¯•ç§پوœ‰è®،هˆ?
        if current_user:
            plan = await service.get_travel_plan(plan_id)
            if plan and (is_admin(current_user) or plan.user_id == current_user.id):
                pass  # وœ‰و‌ƒé™گè®؟é—?
            else:
                plan = None
        
        # ه¦‚و‍œç§پوœ‰è®،هˆ’ن¸چهڈ¯è®؟é—®ï¼Œه°‌è¯•ه…¬ه¼€è®،هˆ’
        if not plan:
            plan = await service.get_public_travel_plan(plan_id)
            if plan:
                is_public = True
        
        if not plan:
            raise HTTPException(status_code=404, detail="و—…è،Œè®،هˆ’ن¸چه­کهœ¨وˆ–و— و‌ƒé™گè®؟é—?)
        
        # èژ·هڈ–ç”¨وˆ·هپڈه¥½ï¼ˆه¦‚و‍œوœ‰ï¼?
        preferences = {}
        if hasattr(plan, 'preferences') and plan.preferences:
            try:
                if isinstance(plan.preferences, str):
                    preferences = json.loads(plan.preferences)
                elif isinstance(plan.preferences, dict):
                    preferences = plan.preferences
            except:
                preferences = {}
        
        # ç”ںوˆگç؛¯و–‡وœ¬و–¹و،?
        generator = PlanGenerator()
        text_plan = await generator.generate_text_plan(
            plan=plan,
            preferences=preferences,
            max_chars=max_chars
        )
        
        result = {
            "plan_id": plan_id,
            "text_plan": text_plan,
            "destination": plan.destination,
            "duration_days": plan.duration_days,
            "generated_at": datetime.utcnow().isoformat(),
            "note": "و­¤و–¹و،ˆهں؛ن؛ژLLMçں¥è¯†ه؛“ç”ںوˆگï¼Œهڈ¯èƒ½وœ‰و»‍هگژو€§ï¼Œن½†ن¸»è¦پو™¯ç‚¹ن؟،وپ¯é€ڑه¸¸وک¯ه‡†ç،®çڑ„م€?
        }
        
        # ç¼“ه­کç»“و‍œï¼?ه°ڈو—¶ = 3600ç§’ï¼‰
        await set_cache(cache_key, result, ttl=3600)
        logger.info(f"ç؛¯و–‡وœ¬و–¹و،ˆه·²ç¼“ه­ک: plan_id={plan_id}")
        
        return result
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"èژ·هڈ–ç؛¯و–‡وœ¬و–¹و،ˆه¤±è´? {e}")
        raise HTTPException(status_code=500, detail=f"ç”ںوˆگç؛¯و–‡وœ¬و–¹و،ˆه¤±è´? {str(e)}")

def _render_plan_html(plan_data: dict) -> str:
    title = plan_data.get("title") or f"و—…è،Œو–¹و،ˆ #{plan_data.get('id', '')}"
    destination = plan_data.get("destination", "")
    description = plan_data.get("description", "")
    score = plan_data.get("score")
    duration_days = plan_data.get("duration_days")
    selected_plan = plan_data.get("selected_plan") or {}
    items = plan_data.get("items") or []
    
    def safe(v):
        return v if v is not None else ""
    
    html = f"""
    <!doctype html>
    <html lang=\"zh\">
    <head>
      <meta charset=\"utf-8\" />
      <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />
      <title>{safe(title)}</title>
      <style>
        body {{ font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Noto Sans', 'Liberation Sans', sans-serif; margin: 24px; color: #222; }}
        h1 {{ margin: 0 0 8px; font-size: 24px; }}
        .meta {{ color: #666; margin-bottom: 16px; }}
        .section {{ margin: 16px 0; }}
        .item {{ border: 1px solid #eee; border-radius: 6px; padding: 12px; margin: 8px 0; }}
        .item-title {{ font-weight: 600; margin-bottom: 6px; }}
        .item-desc {{ color: #555; }}
        table {{ border-collapse: collapse; width: 100%; }}
        th, td {{ border: 1px solid #eee; padding: 8px; text-align: left; }}
      </style>
    </head>
    <body>
      <h1>{safe(title)}</h1>
      <div class=\"meta\">ç›®çڑ„هœ°ï¼ڑ{safe(destination)} | ه¤©و•°ï¼ڑ{safe(duration_days)} | è¯„هˆ†ï¼ڑ{safe(score)}</div>
      <div class=\"section\">
        <h2>و–¹و،ˆç®€ن»?/h2>
        <p class=\"item-desc\">{safe(description)}</p>
      </div>
      <div class=\"section\">
        <h2>وœ€ç»ˆé€‰و‹©çڑ„و–¹و،?/h2>
        <pre style=\"white-space: pre-wrap; background: #fafafa; border: 1px solid #eee; padding: 12px; border-radius: 6px;\">{safe(str(selected_plan))}</pre>
      </div>
      <div class=\"section\">
        <h2>è،Œç¨‹é،¹ç›®</h2>
        {''.join([
          f"<div class='item'><div class='item-title'>{safe(i.get('title'))}</div>"
          f"<div class='item-desc'>{safe(i.get('description'))}</div>"
          f"<div>ç±»ه‍‹ï¼ڑ{safe(i.get('item_type'))}</div>"
          f"<div>ن½چç½®ï¼ڑ{safe(i.get('location'))}</div>"
          f"<div>هœ°ه‌€ï¼ڑ{safe(i.get('address'))}</div>"
          f"</div>" for i in items
        ])}
      </div>
    </body>
    </html>
    """
    return html

@router.get("/{plan_id}/export")
async def export_travel_plan(
    plan_id: int,
    format: str = "pdf",  # pdf, json, html
    db: AsyncSession = Depends(get_async_db),
    current_user: User = Depends(get_current_user),
):
    """ه¯¼ه‡؛و—…è،Œè®،هˆ’ï¼ˆéœ€و‹¥وœ‰وˆ–ç®،çگ†ه‘کï¼?""
    allowed = {"json", "html", "pdf"}
    if format not in allowed:
        raise HTTPException(status_code=400, detail=f"ن¸چو”¯وŒپçڑ„ه¯¼ه‡؛و ¼ه¼ڈ: {format}")
    service = TravelPlanService(db)
    plan = await service.get_travel_plan(plan_id)
    if not plan:
        raise HTTPException(status_code=404, detail="و—…è،Œè®،هˆ’ن¸چه­کهœ?)
    if not (is_admin(current_user) or plan.user_id == current_user.id):
        raise HTTPException(status_code=403, detail="و— و‌ƒه¯¼ه‡؛è¯¥è®،هˆ?)
    plan_data = TravelPlanResponse.from_orm(plan).dict()
    if format == "json":
        return JSONResponse(content=jsonable_encoder(plan_data))
    elif format == "html":
        html = _render_plan_html(plan_data)
        return HTMLResponse(content=html)
    else:  # pdf
        return PlainTextResponse(content="PDF ه¯¼ه‡؛وڑ‚وœھه®‍çژ°", status_code=501)

@router.post("/{plan_id}/export")
async def export_travel_plan_post(
    plan_id: int,
    format: str = "pdf",  # pdf, json, html
    db: AsyncSession = Depends(get_async_db),
    current_user: User = Depends(get_current_user),
):
    """ه¯¼ه‡؛و—…è،Œè®،هˆ’ï¼ˆPOSTï¼ŒهگŒو­¥è؟”ه›‍ï¼Œن¸ژGETن¸€è‡´ï¼‰"""
    return await export_travel_plan(plan_id=plan_id, format=format, db=db, current_user=current_user)

# ذآشِµ¼بë
from app.schemas.travel_plan import QuickGenerateRequest, QuickGenerateResponse

@router.post("/quick-generate", response_model=QuickGenerateResponse)
async def quick_generate_travel_plan(
    request: QuickGenerateRequest,
    db: AsyncSession = Depends(get_async_db),
    current_user: User = Depends(get_current_user),
):
    """ز»¼üةْ³ةآأذذ¼ئ»®£¨°ü؛¬µطح¼ت‎¾ف£©"""
    try:
        from datetime import datetime, timedelta
        import uuid
        
        # ¼ئثمجىت‎
        start_date = datetime.strptime(request.start_date, "%Y-%m-%d")
        end_date = datetime.strptime(request.end_date, "%Y-%m-%d")
        days = (end_date - start_date).days + 1
        
        # ةْ³ة¼ئ»®ID
        plan_id = str(uuid.uuid4())
        
        # ¹¹½¨ئ«؛أت‎¾ف
        preferences = request.preferences or {}
        preferences.update({
            "travelers": request.people,
            "budget": request.budget,
            "departure": request.departure
        })
        
        # ت¹سأPlanGeneratorةْ³ةآأذذ¼ئ»®
        generator = PlanGenerator()
        
        # ´´½¨ءظت±¼ئ»®¶شدَسأسعةْ³ة
        class TempPlan:
            def __init__(self, destination, duration_days, preferences):
                self.destination = destination
                self.duration_days = duration_days
                self.preferences = preferences
        
        temp_plan = TempPlan(request.destination, days, preferences)
        
        # ةْ³ةخؤ±¾¼ئ»®×÷خھ»ù´،
        text_plan = await generator.generate_text_plan(
            plan=temp_plan,
            preferences=preferences,
            max_chars=3000
        )
        
        # ½âخِخؤ±¾¼ئ»®خھ½ل¹¹»¯ت‎¾ف£¨صâہïذèزھتµدضخؤ±¾½âخِآك¼­£©
        daily_itineraries = await _parse_text_to_itineraries(text_plan, request.destination, days, start_date)
        
        # خھأ؟¸ِµطµمجي¼س¾­خ³¶ب
        daily_itineraries = await _add_coordinates_to_itineraries(daily_itineraries, db)
        
        # ¼ئثمآ·دك
        daily_itineraries = await _add_routes_to_itineraries(daily_itineraries)
        
        response = QuickGenerateResponse(
            plan_id=plan_id,
            title=f"{request.destination} {days}جىآأذذ¼ئ»®",
            destination=request.destination,
            days=days,
            people=request.people,
            budget=request.budget,
            start_date=request.start_date,
            end_date=request.end_date,
            daily_itineraries=daily_itineraries,
            generated_at=datetime.utcnow().isoformat()
        )
        
        return response
        
    except Exception as e:
        logger.error(f"ز»¼üةْ³ةآأذذ¼ئ»®ت§°ـ: {e}")
        raise HTTPException(status_code=500, detail=f"ةْ³ةت§°ـ: {str(e)}")

    """½«خؤ±¾¼ئ»®½âخِخھ½ل¹¹»¯ذذ³جت‎¾ف"""
    # صâہïتµدضخؤ±¾½âخِآك¼­£¬½«LLMةْ³ةµؤخؤ±¾×ھ»»خھ½ل¹¹»¯ت‎¾ف
    # شفت±·µ»طؤ£ؤâت‎¾ف£¬تµ¼تتµدضذèزھ½âخِtext_plan
    itineraries = []
    
    for day in range(1, days + 1):
        current_date = start_date + timedelta(days=day-1)
        itinerary = {
            "day": day,
            "date": current_date.strftime("%Y-%m-%d"),
            "theme": f"µع{day}جى - {destination}ج½ث÷",
            "activities": [
                {
                    "name": f"{destination}¾°µمA",
                    "time": "09:00-12:00",
                    "activity": "²خ¹غ",
                    "location": f"{destination}¾°µمA",
                    "description": f"²خ¹غ{destination}ضّأû¾°µمA",
                    "latitude": 39.9 + day * 0.01,  # ؤ£ؤâ¾­خ³¶ب
                    "longitude": 116.4 + day * 0.01,
                    "estimated_cost": 50.0
                },
                {
                    "name": f"{destination}¾°µمB", 
                    "time": "14:00-17:00",
                    "activity": "سخہہ",
                    "location": f"{destination}¾°µمB",
                    "description": f"سخہہ{destination}ضّأû¾°µمB",
                    "latitude": 39.92 + day * 0.01,
                    "longitude": 116.42 + day * 0.01,
                    "estimated_cost": 30.0
                }
            ],
            "routes": [
                {
                    "from_lat": 39.9 + day * 0.01,
                    "from_lng": 116.4 + day * 0.01,
                    "to_lat": 39.92 + day * 0.01,
                    "to_lng": 116.42 + day * 0.01,
                    "distance": "3.5km",
                    "duration": "15·ضضس",
                    "mode": "µطجْ"
                }
            ],
            "meals": [
                {
                    "type": "شç²ح",
                    "time": "08:00",
                    "location": f"{destination}¾ئµê",
                    "suggestion": "¾ئµê×شضْشç²ح"
                },
                {
                    "type": "خç²ح", 
                    "time": "12:30",
                    "location": f"{destination}²حجü",
                    "suggestion": "µ±µطجطة«أہت³"
                },
                {
                    "type": "حي²ح",
                    "time": "18:30", 
                    "location": f"{destination}²حجü",
                    "suggestion": "؛£دت²حجü"
                }
            ]
        }
        itineraries.append(itinerary)
    
    return itineraries

async def _add_coordinates_to_itineraries(itineraries: List[Dict[str, Any]], db: AsyncSession) -> List[Dict[str, Any]]:
    """خھذذ³جضذµؤµطµمجي¼س¾­خ³¶ب×ّ±ê"""
    # صâہï؟ةزشµ÷سأµطح¼API»ٍ²éر¯ت‎¾ف؟â»ٌب،صوتµ×ّ±ê
    # شفت±±£³ضؤ£ؤâت‎¾ف
    return itineraries

async def _add_routes_to_itineraries(itineraries: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
    """خھذذ³ججي¼سآ·دك¹و»®ذإد¢"""
    # صâہï؟ةزشµ÷سأµطح¼API¼ئثمآ·دك
    # شفت±±£³ضؤ£ؤâت‎¾ف
    return itineraries
async def _parse_text_to_itineraries(text_plan: str, destination: str, days: int, start_date: datetime) -> List[Dict[str, Any]]:
    """"½«خؤ±¾¼ئ»®½âخِخھ½ل¹¹»¯ذذ³جت‎¾ف"""
    try:
        import re
        from datetime import datetime, timedelta
        
        itineraries = []
        
        # ت¹سأص‎شٍ±ي´ïت½½âخِخؤ±¾ضذµؤجىت‎؛ح»î¶¯
        # ئ¥إنہàثئ "Day 1:", "µعز»جى:", "D1:" µب¸ٌت½
        day_patterns = [
            r'(?:µع(\d+)جى|Day\s*(\d+)|D(\d+)|day\s*(\d+))[:\s]*',
            r'(\d+)شآ(\d+)بص[:\s]*'  # بصئع¸ٌت½
        ]
        
        # °´ذذ·ض¸îخؤ±¾
        lines = text_plan.split('\n')
        current_day = 0
        current_activities = []
        
        for line in lines:
            line = line.strip()
            if not line:
                continue
                
            # ¼ى²éتا·ٌتاذآµؤز»جى
            day_match = None
            for pattern in day_patterns:
                match = re.search(pattern, line, re.IGNORECASE)
                if match:
                    # ±£´وا°ز»جىµؤت‎¾ف
                    if current_activities and current_day > 0:
                        itinerary = _create_day_itinerary(current_day, start_date, destination, current_activities)
                        itineraries.append(itinerary)
                    
                    # جلب،جىت‎
                    day_num = 0
                    for group in match.groups():
                        if group and group.isdigit():
                            day_num = int(group)
                            break
                    
                    current_day = day_num
                    current_activities = []
                    break
            
            # بç¹ûتا»î¶¯ذذ£¬³¢تش½âخِ
            if current_day > 0 and not day_match:
                activity = _parse_activity_line(line)
                if activity:
                    current_activities.append(activity)
        
        # ±£´و×î؛َز»جىµؤت‎¾ف
        if current_activities and current_day > 0:
            itinerary = _create_day_itinerary(current_day, start_date, destination, current_activities)
            itineraries.append(itinerary)
        
        # بç¹ûأ»سذ½âخِ³ِبخ؛خذذ³ج£¬ةْ³ةؤ¬بدذذ³ج
        if not itineraries:
            for day in range(1, days + 1):
                itinerary = _create_default_day_itinerary(day, start_date, destination)
                itineraries.append(itinerary)
        
        # °´جىت‎إإذٍ
        itineraries.sort(key=lambda x: x['day'])
        
        return itineraries
        
    except Exception as e:
        logger.error(f"½âخِخؤ±¾¼ئ»®ت§°ـ: {e}")
        # ·µ»طؤ¬بدذذ³ج
        itineraries = []
        for day in range(1, days + 1):
            itinerary = _create_default_day_itinerary(day, start_date, destination)
            itineraries.append(itinerary)
        return itineraries

def _parse_activity_line(line: str) -> Optional[Dict[str, Any]]:
    """"½âخِ»î¶¯ذذ"""
    try:
        # ئ¥إنت±¼ن¸ٌت½£¬بç "09:00-12:00", "ةدخç9µم", "9:00" µب
        time_patterns = [
            r'(\d{1,2}:\d{2})\s*[-~]\s*(\d{1,2}:\d{2})',  # 09:00-12:00
            r'(\d{1,2}:\d{2})',  # 09:00
            r'(ةدخç|دآخç|حيةد)\s*(\d{1,2})\s*µم(?:\s*-\s*(\d{1,2})\s*µم)?',  # ةدخç9µم
        ]
        
        time_match = None
        time_str = ""
        for pattern in time_patterns:
            match = re.search(pattern, line)
            if match:
                if len(match.groups()) >= 2 and match.group(2):
                    # ت±¼ن·¶خ§
                    start_time = match.group(1)
                    end_time = match.group(2)
                    time_str = f"{start_time}-{end_time}"
                else:
                    # µ¥¸ِت±¼نµم
                    time_str = match.group(1)
                time_match = match
                break
        
        # زئ³‎ت±¼ن²؟·ض£¬»ٌب،»î¶¯أèتِ
        activity_text = line
        if time_match:
            activity_text = line[:time_match.start()].strip() + " " + line[time_match.end():].strip()
        
        activity_text = activity_text.strip()
        
        if not activity_text:
            return None
            
        # ¼ٍµ¥µؤ»î¶¯½âخِ
        return {
            "name": activity_text[:20],  # »î¶¯أû³ئ
            "time": time_str or "ب«جى",
            "activity": "²خ¹غ",
            "location": activity_text,
            "description": activity_text,
            "estimated_cost": 0.0
        }
        
    except Exception as e:
        logger.warning(f"½âخِ»î¶¯ذذت§°ـ: {line}, ´يخَ: {e}")
        return None

def _create_day_itinerary(day: int, start_date: datetime, destination: str, activities: List[Dict[str, Any]]) -> Dict[str, Any]:
    """"´´½¨ز»جىµؤذذ³ج"""
    current_date = start_date + timedelta(days=day-1)
    
    # بç¹ûأ»سذ»î¶¯£¬جي¼سؤ¬بد»î¶¯
    if not activities:
        activities = [
            {
                "name": f"{destination}×شسة»î¶¯",
                "time": "09:00-18:00",
                "activity": "×شسة»î¶¯",
                "location": f"{destination}تذضذذؤ",
                "description": f"شع{destination}×شسةج½ث÷",
                "estimated_cost": 0.0
            }
        ]
    
    return {
        "day": day,
        "date": current_date.strftime("%Y-%m-%d"),
        "theme": f"µع{day}جى - {destination}ج½ث÷",
        "activities": activities,
        "routes": [],  # ةش؛َ¼ئثم
        "meals": [
            {
                "type": "شç²ح",
                "time": "08:00",
                "location": f"{destination}¾ئµê",
                "suggestion": "¾ئµê×شضْشç²ح"
            },
            {
                "type": "خç²ح", 
                "time": "12:30",
                "location": f"{destination}²حجü",
                "suggestion": "µ±µطجطة«أہت³"
            },
            {
                "type": "حي²ح",
                "time": "18:30", 
                "location": f"{destination}²حجü",
                "suggestion": "جطة«²حجü"
            }
        ]
    }

