@router.get("/tasks/status/{task_id}")
async def get_task_status(task_id: str, current_user: User = Depends(get_current_user)):
    """وں¥è¯¢Celeryن»»هٹ،çٹ¶و€پï¼ˆéœ€ç™»ه½•ï¼?""
    try:
        task_result = AsyncResult(task_id)
        state = task_result.state
        if state == "PENDING":
            return {"task_id": task_id, "status": "pending", "message": "ن»»هٹ،ç­‰ه¾…و‰§è،Œ"}
        if state == "PROGRESS":
            info = task_result.info or {}
            return {
                "task_id": task_id,
                "status": "progress",
                "current": info.get("current", 0),
                "total": info.get("total", 100),
                "message": info.get("status", "و‰§è،Œن¸?),
            }
        if state == "SUCCESS":
            return {"task_id": task_id, "status": "success", "result": task_result.result}
        # FAILURE وˆ–ه…¶ن»–çٹ¶و€?
        return {"task_id": task_id, "status": "failed", "message": str(task_result.info)}
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"èژ·هڈ–ن»»هٹ،çٹ¶و€په¤±è´? {str(e)}")


@router.delete("/tasks/cancel/{task_id}")
async def cancel_task(task_id: str, current_user: User = Depends(get_current_user)):
    """هڈ–و¶ˆCeleryن»»هٹ،ï¼ˆéœ€ç™»ه½•ï¼?""
    try:
        task_result = AsyncResult(task_id)
        task_result.revoke(terminate=True)
        return {"task_id": task_id, "status": "cancelled"}
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"هڈ–و¶ˆن»»هٹ،ه¤±è´¥: {str(e)}")


