@router.post("/{plan_id}/generate")
async def generate_travel_plans(
    plan_id: int,
    request: TravelPlanGenerateRequest,
    db: AsyncSession = Depends(get_async_db),
    current_user: User = Depends(get_current_user),
):
    """ç”ںوˆگو—…è،Œو–¹و،ˆï¼ˆéœ€و‹¥وœ‰وˆ–ç®،çگ†ه‘کï¼?""
    service = TravelPlanService(db)
    agent_service = AgentService(db)
    plan = await service.get_travel_plan(plan_id)
    if not plan:
        raise HTTPException(status_code=404, detail="و—…è،Œè®،هˆ’ن¸چه­کهœ?)
    if not (is_admin(current_user) or plan.user_id == current_user.id):
        raise HTTPException(status_code=403, detail="و— و‌ƒç”ںوˆگè¯¥è®،هˆ?)
    # éک²و­¢é‡چه¤چè§¦هڈ‘ç”ںوˆگن»»هٹ،
    if plan.status == "generating":
        raise HTTPException(status_code=409, detail="è¯¥è®،هˆ’و­£هœ¨ç”ںوˆگن¸­ï¼Œè¯·ç¨چه€?)
    # ه…ˆو›´و–°çٹ¶و€پن¸؛ç”ںوˆگن¸­ه¹¶هٹ é”پï¼Œéپ؟ه…چه¹¶هڈ‘ç«‍ن؛?
    await agent_service._update_plan_status(plan_id, "generating")
    async_result = celery_generate_travel_plans_task.delay(
        plan_id,
        request.preferences,
        request.requirements,
    )
    return {
        "message": "و—…è،Œو–¹و،ˆç”ںوˆگن»»هٹ،ه·²هگ¯هٹ?,
        "plan_id": plan_id,
        "status": "generating",
        "task_id": async_result.id,
    }


