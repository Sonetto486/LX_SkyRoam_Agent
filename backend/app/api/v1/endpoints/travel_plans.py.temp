@router.post("/", response_model=TravelPlanResponse)
async def create_travel_plan(
    plan_data: TravelPlanCreateRequest,
    db: AsyncSession = Depends(get_async_db),
    current_user: User = Depends(get_current_user),
):
    """هˆ›ه»؛و–°çڑ„و—…è،Œè®،هˆ’ï¼ˆç»‘ه®ڑهˆ°ه½“ه‰چç”¨وˆ·ï¼?""
    service = TravelPlanService(db)
    data = plan_data.dict()
    data["user_id"] = current_user.id
    return await service.create_travel_plan(TravelPlanCreate(**data))


@router.get("/")
async def get_travel_plans(
    skip: int = 0,
    limit: int = 100,
    user_id: Optional[int] = None,
    status: Optional[str] = None,
    keyword: Optional[str] = None,
    min_score: Optional[float] = None,
    max_score: Optional[float] = None,
    created_from: Optional[datetime] = Query(None, description="هˆ›ه»؛و—¶é—´èµ?ISO8601, و”¯وŒپZ)"),
    created_to: Optional[datetime] = Query(None, description="هˆ›ه»؛و—¶é—´و­?ISO8601, و”¯وŒپZ)"),
    travel_from: Optional[date] = Query(None, description="ه‡؛è،Œو—¥وœںèµ?YYYY-MM-DD)"),
    travel_to: Optional[date] = Query(None, description="ه‡؛è،Œو—¥وœںو­?YYYY-MM-DD)"),
    plan_source: Optional[str] = Query(
        None,
        description="و–¹و،ˆو‌¥و؛گè؟‡و»¤: private(ن»…ç§پوœ?م€پpublic(ن»…ه…¬ه¼€)م€پوœھن¼ è،¨ç¤؛ه…¨éƒ?,
        regex="^(private|public)$"
    ),
    db: AsyncSession = Depends(get_async_db),
    current_user: User = Depends(get_current_user),
):
    """èژ·هڈ–و—…è،Œè®،هˆ’هˆ—è،¨ï¼ˆو™®é€ڑç”¨وˆ·ن»…èƒ½وں¥çœ‹è‡ھه·±çڑ„ï¼Œç®،çگ†ه‘کهڈ¯وں¥çœ‹و‰€وœ‰ï¼‰"""
    service = TravelPlanService(db)
    # é‌‍ç®،çگ†ه‘که¼؛هˆ¶é™گه®ڑن¸؛ه½“ه‰چç”¨وˆ?
    effective_user_id = user_id if is_admin(current_user) else current_user.id
    plans, total = await service.get_travel_plans_with_total(
        skip=skip,
        limit=limit,
        user_id=effective_user_id,
        status=status,
        keyword=keyword,
        min_score=min_score,
        max_score=max_score,
        created_from=created_from,
        created_to=created_to,
        travel_from=travel_from,
        travel_to=travel_to,
        plan_source=plan_source,
    )
    return {
        "plans": plans,
        "total": total,
        "skip": skip,
        "limit": limit,
    }

